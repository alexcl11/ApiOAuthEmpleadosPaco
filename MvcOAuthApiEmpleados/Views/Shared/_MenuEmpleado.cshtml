@if (Context.User.Identity.IsAuthenticated == true)
{
    <li class="nav-item">
        <a class="nav-link text-dark"
           asp-controller="Empleados"
           asp-action="Index">Empleados</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-danger"
           asp-controller="Managed"
           asp-action="LogOut">
           Log out @Context.User.Identity.Name
        </a>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark"
           asp-controller="Empleados"
           asp-action="Index">Log In</a>
    </li>
}